generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum PostType {
  TEXT
  PHOTO
  VIDEO_LINK
  REEL
}

enum FriendsFeedReviewStatus {
  READ
  SAVED
  DISCARDED
}

model User {
  id               String        @id @default(uuid())
  fbUserId         String?
  email            String?
  displayName      String
  username         String        @unique
  profilePicUrl    String?
  bannerImageKey   String?
  /// object-position X for banner crop (0–100, default center).
  bannerPositionX  Float         @default(50)
  /// object-position Y for banner crop (0–100, default center).
  bannerPositionY  Float         @default(50)
  postsAuthored    Post[]        @relation("PostAuthor")
  postsOnWall      Post[]        @relation("PostProfileOwner")
  comments         Comment[]
  requestedFriends Friendship[]  @relation("FriendshipRequester")
  receivedFriends  Friendship[]  @relation("FriendshipAddressee")
  friendsFeedReviews FriendsFeedReview[]
  postReactions    PostReaction[]
  feedbackItems    FeedbackItem[]
  feedbackComments FeedbackComment[]
  messageThreadsCreated MessageThread[] @relation("MessageThreadCreator")
  messageParticipations MessageThreadParticipant[]
  messageFolders        MessageFolder[]
  messagesAuthored      Message[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model MessageThread {
  id                String   @id @default(uuid())
  subject           String
  createdById       String
  participantLowId  String
  participantHighId String
  createdBy         User     @relation("MessageThreadCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants      MessageThreadParticipant[]
  messages          Message[]
  lastMessageAt     DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([participantLowId, participantHighId, subject])
  @@index([lastMessageAt(sort: Desc)])
  @@index([participantLowId, participantHighId])
}

enum MessageFolderKind {
  CUSTOM
  SAVED
  ARCHIVED
  TRASH
}

model MessageFolder {
  id             String              @id @default(uuid())
  userId         String
  name           String
  kind           MessageFolderKind     @default(CUSTOM)
  sortOrder      Int                   @default(0)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants   MessageThreadParticipant[]
  createdAt      DateTime              @default(now())

  @@unique([userId, name])
  @@index([userId, sortOrder])
}

model MessageThreadParticipant {
  id          String         @id @default(uuid())
  threadId    String
  userId      String
  folderId    String?
  /// Set when the viewer moves the thread to Trash; used for 30-day auto-purge.
  trashedAt   DateTime?
  lastReadAt  DateTime       @default(now())
  thread      MessageThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder      MessageFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@unique([threadId, userId])
  @@index([userId])
  @@index([userId, folderId])
}

model Message {
  id        String        @id @default(uuid())
  threadId  String
  authorId  String
  text      String
  editedAt  DateTime?
  deletedAt DateTime?
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([threadId, createdAt])
}

model Friendship {
  id           String             @id @default(uuid())
  requesterId  String
  addresseeId  String
  status       FriendshipStatus
  requester    User               @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee    User               @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
}

model Post {
  id              String   @id @default(uuid())
  authorId        String
  profileOwnerId  String
  type            PostType
  text            String?
  photoKey        String?
  /// User caption (photos, FB import); Postgres TEXT, max 4000 chars in app.
  photoCaption    String?
  videoUrl              String?
  /// Open-graph / inferred title when type is VIDEO_LINK (any shared URL).
  linkTitle            String?
  linkDescription      String?
  /// Resized hero image stored in blob storage (fixed layout on clients).
  linkPreviewImageKey  String?
  isPinned        Boolean  @default(false)
  /// When true, post may appear on friends' "Friends feed" tab (own wall only).
  sharedToFriendsFeed Boolean @default(false)
  /// TEXT post styling (nullable for legacy rows and non-text types).
  textBackgroundColor String?
  textColor           String?
  textFontSize        Int?
  /// Original Facebook post id when imported from Graph API.
  fbPostId             String?  @unique
  author          User     @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  profileOwner    User     @relation("PostProfileOwner", fields: [profileOwnerId], references: [id], onDelete: Cascade)
  comments        Comment[]
  friendsFeedReviews FriendsFeedReview[]
  reactions       PostReaction[]
  syndication     PostSyndication?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([profileOwnerId, createdAt(sort: Desc)])
}

model PostSyndication {
  id              String   @id @default(uuid())
  token           String   @unique
  postId          String   @unique
  createdByUserId String
  /// When true, commenters (not the post author) appear under stable random aliases.
  randomizeNames  Boolean  @default(true)
  /// Frozen post + flat comment list for the public read-only page.
  snapshotJson    Json
  refreshedAt     DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  post    Post                    @relation(fields: [postId], references: [id], onDelete: Cascade)
  aliases PostSyndicationAlias[]

  @@index([createdByUserId])
}

model PostSyndicationAlias {
  id            String   @id @default(uuid())
  syndicationId String
  userId        String
  alias         String
  createdAt     DateTime @default(now())

  syndication PostSyndication @relation(fields: [syndicationId], references: [id], onDelete: Cascade)

  @@unique([syndicationId, userId])
  @@unique([syndicationId, alias])
  @@index([syndicationId])
}

model PostReaction {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  /// Reaction id from shared POST_REACTIONS catalog (e.g. like, agree).
  kind      String
  /// Optional free-text when kind collects details (e.g. disagree).
  details   String?
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, userId])
  @@index([postId, kind])
}

model Comment {
  id        String    @id @default(uuid())
  postId    String
  authorId  String?
  /// Null = top-level comment on the post; otherwise a reply (infinite depth).
  parentId  String?
  text      String
  /// Set when the author deletes their account — row kept for reply threading.
  deletedAt DateTime?
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([postId, createdAt])
  @@index([parentId])
  @@index([authorId])
}

model FriendsFeedReview {
  id        String                  @id @default(uuid())
  viewerId  String
  postId    String
  status    FriendsFeedReviewStatus
  viewer    User                    @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  post      Post                    @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@unique([viewerId, postId])
  @@index([viewerId, status, updatedAt(sort: Desc)])
}

model BlogEntry {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  body        String
  committedAt DateTime
  sha         String   @unique
  authorName  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([committedAt(sort: Desc)])
}

model FeedbackItem {
  id        String             @id @default(uuid())
  authorId  String
  title     String
  body      String
  author    User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  FeedbackComment[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([createdAt(sort: Desc)])
}

model FeedbackComment {
  id         String            @id @default(uuid())
  feedbackId String
  authorId   String
  parentId   String?
  text       String
  feedback   FeedbackItem      @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  author     User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent     FeedbackComment?  @relation("FeedbackCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    FeedbackComment[] @relation("FeedbackCommentReplies")
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([feedbackId, createdAt])
  @@index([parentId])
}
