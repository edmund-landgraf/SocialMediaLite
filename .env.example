# SocialMediaLite — environment template (copy to `.env` in repo root)
#
# Dev:  Windows (Node/npm) + Postgres in WSL2 Docker (docker compose up -d)
# Prod: Linux VPS — nginx + /var/www + PM2 (see scripts/deploy-prod.sh)

# Database — Postgres in WSL2 Docker publishes 5432 to Windows localhost.
# Start: from repo root in WSL, `docker compose up -d`
# Windows Node/API connects via localhost:5432 (Docker Desktop port forward).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/socialmedialite?schema=public"

# API
API_PORT=3001
NODE_ENV=development
WEB_ORIGIN=http://localhost:5174
SESSION_SECRET=change-me-to-a-long-random-string

# Facebook Login — SocialMediaLite app (public_profile + email for sign-in; user_posts for timeline import)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Must match how you open the app in the browser (Vite dev uses port 5174, not the API port).
FACEBOOK_REDIRECT_URI=http://localhost:5174/api/auth/facebook/callback
# Share Dialog redirect after timeline post — HTTPS on App Domains (not localhost); add to Valid OAuth Redirect URIs
FACEBOOK_SHARE_REDIRECT_URI=https://unwhelm.online/
FACEBOOK_GRAPH_API_VERSION=v20.0

# Public HTTPS base for syndication links in Facebook Page posts (required for link preview when testing on localhost)
SYNDICATION_PUBLIC_BASE_URL=https://unwhelm.online

# Facebook WritePostsOnly app — syndication "Push to Facebook Page"
# Separate Meta app; see docs/PUSH_TO_FB.md. OAuth callback is a different path from login/import.
FACEBOOK_WRITE_POSTS_APP_ID=
FACEBOOK_WRITE_POSTS_APP_SECRET=
FACEBOOK_WRITE_POSTS_REDIRECT_URI=http://localhost:5174/api/auth/facebook/pages/callback
# Facebook Login for Business — Configuration ID (optional; if omitted, uses scope= below)
# Include pages_show_list, pages_manage_posts, AND pages_read_engagement (Meta bundles the last one).
# FACEBOOK_WRITE_POSTS_CONFIG_ID=
# Debug logs (JSON lines): apps/api/logs/facebook-login.log, apps/api/logs/facebook-write-posts.log

# Optional: path to yt-dlp binary for link previews + inline playback (otherwise auto-downloaded to apps/api/.cache/yt-dlp)
# Linux prod: run ./scripts/check-ytdlp-prod.sh on VPS; install ffmpeg for reliable Instagram/TikTok inline mux
# YT_DLP_PATH=

# STORAGE_PROVIDER=local | s3 (Phase 1: only `local` is implemented; `s3` is stubbed)
STORAGE_PROVIDER=local
# Local dev: relative to apps/api cwd when using `npm run dev -w apps/api`.
# Production (PM2): ecosystem.config.cjs sets an absolute STORAGE_LOCAL_ROOT.
STORAGE_LOCAL_ROOT=./storage

# S3 stubs (ignored until STORAGE_PROVIDER=s3 is implemented)
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Web — optional API origin for a future split deploy (built into the Vite bundle).
# Leave empty for same-origin `/api/...` (recommended today):
#   local dev: Vite proxies /api → localhost:3001
#   production (Linux/nginx): static files in /var/www/unwhelm.online;
#     nginx proxies /api and /assets → 127.0.0.1:3001 (see deploy/nginx/unwhelm.online.conf)
# If API moves to another host later, set origin only (NOT .../api):
#   VITE_API_URL=https://api.unwhelm.online
VITE_API_URL=

# Blog — sync commit history from GitHub on API startup (optional)
# GITHUB_TOKEN=
# GITHUB_REPO_OWNER=
# GITHUB_REPO_NAME=

# AI profile summaries — requires a running Ollama (or OpenAI-compatible) server
# docs/OLLAMA_VPS_SETUP.md, docs/plan/ai-profile-summaries.plan.md
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2:3b
# LLM_TIMEOUT_MS=120000
# AI_SUMMARY_MAX_POSTS=200
# AI_SUMMARY_PER_POST_CHARS=4000
# AI_SUMMARY_MAX_CORPUS_CHARS=48000
# AI_SUMMARY_MAX_COMMENTS=100
# Hosted (Groq/Gemini/OpenAI): set LLM_BASE_URL + OPENAI_API_KEY per provider
# OPENAI_API_KEY=
