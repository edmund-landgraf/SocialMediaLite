# SocialMediaLite — environment template (copy to `.env` in repo root)
#
# Dev:  Windows (Node/npm) + Postgres in WSL2 Docker (docker compose up -d)
# Prod: Linux VPS — nginx + /var/www + PM2 (see scripts/deploy-prod.sh)

# Database — Postgres in WSL2 Docker publishes 5432 to Windows localhost.
# Start: from repo root in WSL, `docker compose up -d`
# Windows Node/API connects via localhost:5432 (Docker Desktop port forward).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/socialmedialite?schema=public"

# API
API_PORT=3001
NODE_ENV=development
WEB_ORIGIN=http://localhost:5174
SESSION_SECRET=change-me-to-a-long-random-string

# Facebook Login (public_profile + email: name, email, profile picture)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3001/api/auth/facebook/callback
FACEBOOK_GRAPH_API_VERSION=v20.0

# STORAGE_PROVIDER=local | s3 (Phase 1: only `local` is implemented; `s3` is stubbed)
STORAGE_PROVIDER=local
# Local dev: relative to apps/api cwd when using `npm run dev -w apps/api`.
# Production (PM2): ecosystem.config.cjs sets an absolute STORAGE_LOCAL_ROOT.
STORAGE_LOCAL_ROOT=./storage

# S3 stubs (ignored until STORAGE_PROVIDER=s3 is implemented)
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Web — optional API origin for a future split deploy (built into the Vite bundle).
# Leave empty for same-origin `/api/...` (recommended today):
#   local dev: Vite proxies /api → localhost:3001
#   production (Linux/nginx): static files in /var/www/unwhelm.online;
#     nginx proxies /api and /assets → 127.0.0.1:3001 (see deploy/nginx/unwhelm.online.conf)
# If API moves to another host later, set origin only (NOT .../api):
#   VITE_API_URL=https://api.unwhelm.online
VITE_API_URL=
